{
    "name": "ez-php/contracts",
    "version": "1.1.1",
    "description": "Shared interfaces and abstract base classes for the ez-php framework \u2014 zero framework coupling for standalone modules",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "contracts",
        "interfaces",
        "dependency-injection",
        "php",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/contracts",
    "support": {
        "issues": "https://github.com/ez-php/contracts/issues",
        "source": "https://github.com/ez-php/contracts"
    },
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "ez-php/http": "^1.1"
    },
    "require-dev": {
        "ez-php/docker": "^1.1",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "ez-php/testing-application": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\Contracts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
